# vllm-bench GUI — machine-specific settings. TEMPLATE.
#
# `./setup.sh` copies this to .env and fills in the paths it detects, so on a
# new machine you normally just run setup.sh. Edit .env afterwards if anything
# is wrong — it is the ONE file that knows about this machine.
#
# .env is sourced by run.sh and bin/vllm. No secrets belong here: the HF token
# is stored in the app DB via the Settings page, alongside model dir, port range
# and the SLURM options.

# --- Web app ---------------------------------------------------------------
# Where the GUI listens. 0.0.0.0 exposes it on the LAN (no auth in v1).
HOST=127.0.0.1
PORT=5173

# --- Conda env -------------------------------------------------------------
# Env holding every Python dep (see requirements.txt). run.sh uses this env's
# interpreter directly, so the app runs correctly even without `conda activate`.
# setup.sh fills CONDA_ENV_PATH in from `conda info --base`.
CONDA_ENV_NAME=vllm-bench-gui
CONDA_ENV_PATH=

# --- vLLM container --------------------------------------------------------
# Absolute path to the Apptainer image providing the `vllm` command; bin/vllm
# runs it. apptainer is the only thing assumed from the system (plus SLURM on a
# cluster). setup.sh picks the largest .sif under ../vllm/container/.
VLLM_SIF=

# --- GPU selection ---------------------------------------------------------
# Which GPU(s) vLLM may use, as nvidia-smi indices (`nvidia-smi -L` to list).
# Use "0,1" for two GPUs and raise the run's tensor-parallel-size to match.
#
# NOTE for this project's workstation: 0 = RTX 5000 Ada (32 GB, compute),
# 1 = RTX A400 (display-only — never use for compute).
CUDA_VISIBLE_DEVICES=0
# Keep CUDA's numbering identical to nvidia-smi's. Required when the cards are
# not identical, otherwise index 0 may not be the GPU you think it is.
CUDA_DEVICE_ORDER=PCI_BUS_ID
